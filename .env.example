# Copy this file to .env and replace every change-me value before running the project.
# Do not commit the real .env file.

# PostgreSQL source database
POSTGRES_USER=change-me-postgres-user
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=banking
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_CONTAINER_HOST=postgres
POSTGRES_CONTAINER_PORT=5432

# MinIO object storage
MINIO_ROOT_USER=change-me-minio-root-user
MINIO_ROOT_PASSWORD=change-me-minio-root-password
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=change-me-minio-access-key
MINIO_SECRET_KEY=change-me-minio-secret-key
MINIO_BUCKET=raw
MINIO_DLQ_PREFIX=dlq

# Kafka and Debezium
KAFKA_BOOTSTRAP=localhost:29092
KAFKA_GROUP=minio-consumer-group
DEBEZIUM_CONNECT_URL=http://localhost:8083/connectors
DEBEZIUM_CONNECTOR_NAME=banking-postgres-connector
DEBEZIUM_TOPIC_PREFIX=banking_server

# Generator and consumer tuning
GENERATOR_SLEEP_SECONDS=5
GENERATOR_MAX_ITERATIONS=0
CONSUMER_BATCH_SIZE=50
CONSUMER_FLUSH_INTERVAL_SECONDS=20
CONSUMER_UPLOAD_RETRIES=3
INITIAL_BALANCE_MIN=100.00
INITIAL_BALANCE_MAX=10000.00
MAX_TXN_AMOUNT=1000.00
MINIMUM_CUSTOMERS=10
MINIMUM_ACCOUNTS=15

# Airflow metadata database and web UI
AIRFLOW_DB_USER=change-me-airflow-db-user
AIRFLOW_DB_PASSWORD=change-me-airflow-db-password
AIRFLOW_DB_NAME=airflow
AIRFLOW_ADMIN_USER=change-me-airflow-admin-user
AIRFLOW_ADMIN_PASSWORD=change-me-airflow-admin-password
AIRFLOW_ADMIN_EMAIL=admin@example.com
AIRFLOW__WEBSERVER__SECRET_KEY=change-me-airflow-webserver-secret
AIRFLOW__CORE__FERNET_KEY=change-me-airflow-fernet-key

# Snowflake
SNOWFLAKE_ACCOUNT=change-me-snowflake-account
SNOWFLAKE_USER=change-me-snowflake-user
SNOWFLAKE_PASSWORD=change-me-snowflake-password
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DB=BANKING
SNOWFLAKE_SCHEMA=ANALYTICS
SNOWFLAKE_ROLE=change-me-snowflake-role
