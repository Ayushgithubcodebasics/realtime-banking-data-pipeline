# ============================================================
# Copy this file to .env before first run.
# Values below are safe examples only.
# ============================================================

# PostgreSQL (Docker internal names are handled by compose services)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123
POSTGRES_DB=banking
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_CONTAINER_HOST=postgres
POSTGRES_CONTAINER_PORT=5432

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=raw
MINIO_DLQ_PREFIX=dlq

# Kafka / Debezium
KAFKA_BOOTSTRAP=localhost:29092
KAFKA_GROUP=minio-consumer-group
DEBEZIUM_CONNECT_URL=http://localhost:8083/connectors
DEBEZIUM_CONNECTOR_NAME=banking-postgres-connector
DEBEZIUM_TOPIC_PREFIX=banking_server

# Generator / consumer tuning
GENERATOR_SLEEP_SECONDS=5
CONSUMER_BATCH_SIZE=50
CONSUMER_FLUSH_INTERVAL_SECONDS=20
INITIAL_BALANCE_MIN=100.00
INITIAL_BALANCE_MAX=10000.00
MAX_TXN_AMOUNT=1000.00
MINIMUM_CUSTOMERS=10
MINIMUM_ACCOUNTS=15

# Airflow metadata DB + admin account
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=airflow123
AIRFLOW_DB_NAME=airflow
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=ChangeThisPassword123!
AIRFLOW_ADMIN_EMAIL=admin@banking.local
AIRFLOW__WEBSERVER__SECRET_KEY=replace-with-random-32-char-secret
AIRFLOW__CORE__FERNET_KEY=replace-with-generated-fernet-key

# Snowflake
SNOWFLAKE_ACCOUNT=<orgname-accountname>
SNOWFLAKE_USER=<your_snowflake_username>
SNOWFLAKE_PASSWORD=<your_snowflake_password>
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DB=BANKING
SNOWFLAKE_SCHEMA=ANALYTICS
SNOWFLAKE_ROLE=TRANSFORMER
